---
import BaseLayout from '../layouts/BaseLayout.astro';

const colors = {
  brand: [
    { name: 'Brand / Black',   token: '--color-brand-black',   hex: '#000000', figma: 'Brand/Black' },
    { name: 'Brand / White',   token: '--color-brand-white',   hex: '#FFFFFF', figma: 'Brand/White' },
    { name: 'Brand / Orange',  token: '--color-brand-orange',  hex: '#FF5B01', figma: 'Brand/Accent Orange' },
  ],
  neutral: [
    { name: 'Neutral / Medium Gray', token: '--color-neutral-gray',   hex: '#999999', figma: 'Neutral/Medium Gray' },
    { name: 'Neutral / Border Gray', token: '--color-neutral-border', hex: '#DADADA', figma: 'Neutral/Border Gray' },
  ],
  background: [
    { name: 'Background / Warm Cream',  token: '--color-bg-cream',      hex: '#F5F4F0', figma: 'Background/Warm Cream' },
    { name: 'Background / Light Gray',  token: '--color-bg-light',      hex: '#F1F1F1', figma: 'Background/Light Gray' },
    { name: 'Background / Warm Gray',   token: '--color-bg-warm-gray',  hex: '#DBDBDA', figma: 'Background/Warm Gray' },
    { name: 'Background / Dark Olive',  token: '--color-bg-dark-olive', hex: '#6D6E5E', figma: 'Background/Dark Olive' },
  ],
  overlay: [
    { name: 'Overlay / Glass Dark 30', token: '--color-overlay-dark', hex: '#161616', figma: 'Overlay/Glass Dark 30' },
  ],
};

function luminance(hex: string) {
  const r = parseInt(hex.slice(1,3),16)/255;
  const g = parseInt(hex.slice(3,5),16)/255;
  const b = parseInt(hex.slice(5,7),16)/255;
  return 0.2126*r + 0.7152*g + 0.0722*b;
}
---

<BaseLayout title="Colors" activeNav="colors">
  <div class="page-hero">
    <div class="page-hero-eyebrow">Foundations</div>
    <h1 class="page-hero-title">Colors</h1>
    <p class="page-hero-desc">
      10 color tokens extracted from Figma. Named to reflect their role in the design system —
      brand identity, neutral surfaces, and background layers.
    </p>
    <div class="page-hero-meta">
      <div class="page-hero-meta-item"><strong>Total</strong>10 tokens</div>
      <div class="page-hero-meta-item"><strong>Groups</strong>Brand · Neutral · Background · Overlay</div>
      <div class="page-hero-meta-item"><strong>Source</strong>Figma variables</div>
    </div>
  </div>

  <!-- Brand Colors -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">01</span>
      <div>
        <div class="ds-section-title">Brand</div>
        <div class="ds-section-subtitle">Core identity colors — used for primary text, backgrounds, and the signature orange accent</div>
      </div>
    </div>
    <div class="swatch-grid">
      {colors.brand.map(c => (
        <div class="swatch-card">
          <div class="swatch-color" style={`background:${c.hex};${c.hex === '#FFFFFF' ? 'border-bottom:1px solid #e5e5e5;' : ''}`}></div>
          <div class="swatch-info">
            <div class="swatch-name">{c.name}</div>
            <div class="swatch-hex">{c.hex}</div>
            <div class="swatch-token">{c.token}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Neutral Colors -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">02</span>
      <div>
        <div class="ds-section-title">Neutral</div>
        <div class="ds-section-subtitle">Used for secondary text, dividers, and subtle UI borders</div>
      </div>
    </div>
    <div class="swatch-grid">
      {colors.neutral.map(c => (
        <div class="swatch-card">
          <div class="swatch-color" style={`background:${c.hex};`}></div>
          <div class="swatch-info">
            <div class="swatch-name">{c.name}</div>
            <div class="swatch-hex">{c.hex}</div>
            <div class="swatch-token">{c.token}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Background Colors -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">03</span>
      <div>
        <div class="ds-section-title">Backgrounds</div>
        <div class="ds-section-subtitle">Surface and page backgrounds — warm tones that complement the brand palette</div>
      </div>
    </div>
    <div class="swatch-grid">
      {colors.background.map(c => (
        <div class="swatch-card">
          <div class="swatch-color" style={`background:${c.hex};`}></div>
          <div class="swatch-info">
            <div class="swatch-name">{c.name}</div>
            <div class="swatch-hex">{c.hex}</div>
            <div class="swatch-token">{c.token}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Overlay Colors -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">04</span>
      <div>
        <div class="ds-section-title">Overlay</div>
        <div class="ds-section-subtitle">Used for glassmorphism and translucent surface effects</div>
      </div>
    </div>
    <div class="swatch-grid">
      {colors.overlay.map(c => (
        <div class="swatch-card">
          <div class="swatch-color" style={`background:${c.hex};`}></div>
          <div class="swatch-info">
            <div class="swatch-name">{c.name}</div>
            <div class="swatch-hex">{c.hex}</div>
            <div class="swatch-token">{c.token}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Token Reference Table -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">05</span>
      <div>
        <div class="ds-section-title">Token Reference</div>
        <div class="ds-section-subtitle">Complete token map — CSS custom properties for all color values</div>
      </div>
    </div>
    <table class="token-table">
      <thead>
        <tr>
          <th>Preview</th>
          <th>Token</th>
          <th>Value</th>
          <th>Figma Style Name</th>
          <th>Usage</th>
        </tr>
      </thead>
      <tbody>
        {[...colors.brand, ...colors.neutral, ...colors.background, ...colors.overlay].map(c => (
          <tr>
            <td>
              <div style={`width:32px;height:32px;border-radius:6px;background:${c.hex};border:1px solid rgba(0,0,0,0.08);`}></div>
            </td>
            <td><code class="token-name">{c.token}</code></td>
            <td><code class="token-value">{c.hex}</code></td>
            <td style="font-size:12px;color:#666;">{c.figma}</td>
            <td style="font-size:12px;color:#999;">
              {c.token.includes('brand-black') && 'Primary text, dark backgrounds'}
              {c.token.includes('brand-white') && 'Text on dark, light backgrounds'}
              {c.token.includes('brand-orange') && 'CTA buttons, accents, highlights'}
              {c.token.includes('neutral-gray') && 'Secondary text, placeholders'}
              {c.token.includes('neutral-border') && 'Dividers, card borders'}
              {c.token.includes('bg-cream') && 'Page background, section alternates'}
              {c.token.includes('bg-light') && 'Input backgrounds, subtle fills'}
              {c.token.includes('bg-warm-gray') && 'Alternate section backgrounds'}
              {c.token.includes('bg-dark-olive') && 'Muted dark accent surfaces'}
              {c.token.includes('overlay-dark') && 'Glass effect backgrounds'}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Usage Guidelines -->
  <div class="ds-section">
    <div class="ds-section-header">
      <span class="ds-section-num">06</span>
      <div>
        <div class="ds-section-title">Usage Guidelines</div>
        <div class="ds-section-subtitle">How colors are combined in the Odama design</div>
      </div>
    </div>
    <div class="usage-combos">
      <div class="usage-combo">
        <div class="usage-combo-preview" style="background:#000;color:#fff;padding:20px;border-radius:8px;font-weight:500;">
          Black on Black
        </div>
        <div class="usage-combo-meta">
          <div class="usage-combo-name">Dark Surface</div>
          <div class="usage-combo-desc">Brand/Black bg + Brand/White text — used for hero sections, CTAs, navigation</div>
        </div>
      </div>
      <div class="usage-combo">
        <div class="usage-combo-preview" style="background:#F5F4F0;color:#000;padding:20px;border-radius:8px;font-weight:500;">
          Warm Surface
        </div>
        <div class="usage-combo-meta">
          <div class="usage-combo-name">Warm Cream Surface</div>
          <div class="usage-combo-desc">Background/Warm Cream bg + Brand/Black text — default page background</div>
        </div>
      </div>
      <div class="usage-combo">
        <div class="usage-combo-preview" style="background:#FF5B01;color:#fff;padding:20px;border-radius:8px;font-weight:500;">
          Orange CTA
        </div>
        <div class="usage-combo-meta">
          <div class="usage-combo-name">Accent CTA</div>
          <div class="usage-combo-desc">Brand/Orange bg + Brand/White text — primary call-to-action buttons</div>
        </div>
      </div>
      <div class="usage-combo">
        <div class="usage-combo-preview" style="background:#fff;color:#000;border:1px solid #DADADA;padding:20px;border-radius:8px;font-weight:500;">
          Card Surface
        </div>
        <div class="usage-combo-meta">
          <div class="usage-combo-name">Card / Panel</div>
          <div class="usage-combo-desc">Brand/White bg + Neutral/Border Gray border — for cards, panels, inputs</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .usage-combos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }
  .usage-combo-preview {
    margin-bottom: 12px;
    min-height: 72px;
    display: flex;
    align-items: center;
  }
  .usage-combo-name {
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .usage-combo-desc {
    font-size: 12px;
    color: #999;
    line-height: 1.4;
  }
</style>
