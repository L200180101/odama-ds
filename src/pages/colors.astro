---
import BaseLayout from '../layouts/BaseLayout.astro';

const groups = [
  {
    label: '01 — Brand', title: 'Brand', subtitle: 'Core identity — primary text, backgrounds, and the signature orange accent',
    swatches: [
      { name: 'Brand / Black',  hex: '#000000', token: '--color-brand-black',   figma: 'Brand/Black',        usage: 'Primary text, dark backgrounds' },
      { name: 'Brand / White',  hex: '#FFFFFF', token: '--color-brand-white',   figma: 'Brand/White',        usage: 'Text on dark, light fills' },
      { name: 'Brand / Orange', hex: '#FF5B01', token: '--color-brand-orange',  figma: 'Brand/Accent Orange', usage: 'CTA buttons, accents, highlights' },
    ]
  },
  {
    label: '02 — Neutral', title: 'Neutral', subtitle: 'Secondary text, dividers, and UI borders',
    swatches: [
      { name: 'Medium Gray',  hex: '#999999', token: '--color-neutral-gray',   figma: 'Neutral/Medium Gray', usage: 'Secondary text, placeholders' },
      { name: 'Border Gray',  hex: '#DADADA', token: '--color-neutral-border', figma: 'Neutral/Border Gray', usage: 'Dividers, card borders, inputs' },
    ]
  },
  {
    label: '03 — Backgrounds', title: 'Backgrounds', subtitle: 'Warm tones for surfaces and page layers',
    swatches: [
      { name: 'Warm Cream',  hex: '#F5F4F0', token: '--color-bg-cream',      figma: 'Background/Warm Cream',  usage: 'Page background, section alternates' },
      { name: 'Light Gray',  hex: '#F1F1F1', token: '--color-bg-light',      figma: 'Background/Light Gray',  usage: 'Input backgrounds, subtle fills' },
      { name: 'Warm Gray',   hex: '#DBDBDA', token: '--color-bg-warm-gray',  figma: 'Background/Warm Gray',   usage: 'Alternate section backgrounds' },
      { name: 'Dark Olive',  hex: '#6D6E5E', token: '--color-bg-dark-olive', figma: 'Background/Dark Olive',  usage: 'Muted dark accent surfaces' },
    ]
  },
  {
    label: '04 — Overlay', title: 'Overlay', subtitle: 'Glass effect and dark translucent surfaces',
    swatches: [
      { name: 'Glass Dark 30', hex: '#161616', token: '--color-overlay-dark', figma: 'Overlay/Glass Dark 30', usage: 'Glassmorphism backgrounds' },
    ]
  },
];
---
<BaseLayout title="Colors" activeNav="colors">

  <div class="page-hero">
    <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>Foundations</div>
    <h1 class="hero-title"><em>Colors</em></h1>
    <p class="hero-desc">10 color tokens extracted directly from Figma — named to reflect their semantic role in the design system.</p>
    <div class="hero-meta">
      <div class="hero-meta-item"><span class="hero-meta-label">Total</span><span class="hero-meta-value">10 tokens</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Groups</span><span class="hero-meta-value">Brand · Neutral · Background · Overlay</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Source</span><span class="hero-meta-value">Figma variables</span></div>
    </div>
  </div>

  {groups.map(g => (
    <div class="ds-section">
      <div class="section-header">
        <div class="section-label">{g.label}</div>
        <div class="section-title">{g.title}</div>
        <div class="section-subtitle">{g.subtitle}</div>
      </div>
      <div class="swatch-grid">
        {g.swatches.map(s => (
          <div class="swatch-card">
            <div class="swatch-color" style={`background:${s.hex};${s.hex==='#FFFFFF'?'border-bottom:1px solid var(--border);':''}`}></div>
            <div class="swatch-body">
              <div class="swatch-name">{s.name}</div>
              <div class="swatch-hex">{s.hex}</div>
              <div class="swatch-token">{s.token}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <!-- Full token table -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">05 — Reference</div>
      <div class="section-title">Token Map</div>
      <div class="section-subtitle">Complete CSS custom properties for all color tokens</div>
    </div>
    <table class="token-table">
      <thead>
        <tr><th>Preview</th><th>Token</th><th>Value</th><th>Figma Style</th><th>Usage</th></tr>
      </thead>
      <tbody>
        {groups.flatMap(g => g.swatches).map(s => (
          <tr>
            <td><div style={`width:28px;height:28px;border-radius:6px;background:${s.hex};border:1px solid rgba(0,0,0,0.08);flex-shrink:0;`}></div></td>
            <td><code class="t-name">{s.token}</code></td>
            <td><code class="t-val">{s.hex}</code></td>
            <td><span class="t-desc">{s.figma}</span></td>
            <td><span class="t-desc">{s.usage}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Usage combos -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">06 — Combinations</div>
      <div class="section-title">Color Pairings</div>
      <div class="section-subtitle">How colors are combined across the Odama website</div>
    </div>
    <div class="combo-grid">
      <div class="combo-card">
        <div class="combo-preview" style="background:#000;color:#fff;">Black / White</div>
        <div class="combo-desc">Hero sections, CTAs, navigation — Brand/Black bg + Brand/White text</div>
      </div>
      <div class="combo-card">
        <div class="combo-preview" style="background:#F5F4F0;color:#000;">Warm Surface</div>
        <div class="combo-desc">Default page background — Warm Cream bg + Brand/Black text</div>
      </div>
      <div class="combo-card">
        <div class="combo-preview" style="background:#FF5B01;color:#fff;">Orange CTA</div>
        <div class="combo-desc">Primary call-to-action — Brand/Orange bg + Brand/White text</div>
      </div>
      <div class="combo-card">
        <div class="combo-preview" style="background:#fff;color:#000;border:1px solid #DADADA;">Card Surface</div>
        <div class="combo-desc">Cards and panels — Brand/White bg + Border Gray outline</div>
      </div>
    </div>
  </div>

</BaseLayout>
<style>
  .combo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
  .combo-card { border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; background: var(--bg-surface); box-shadow: var(--shadow-xs); }
  .combo-preview { padding: 20px; font-size: 15px; font-weight: 500; min-height: 72px; display: flex; align-items: center; }
  .combo-desc { padding: 10px 14px; font-size: 11px; color: var(--text-tertiary); line-height: 1.5; }
</style>
