---
import BaseLayout from '../layouts/BaseLayout.astro';

const shadows = [
  { name: 'Shadow / XS',       token: '--shadow-xs',       value: '0 1px 2px rgba(16,24,40,0.05)',                                    level: 1, usage: 'Subtle lift — swatches, small cards' },
  { name: 'Shadow / Small',    token: '--shadow-sm',        value: '0 1px 3px rgba(16,24,40,0.10), 0 1px 2px rgba(16,24,40,0.06)',    level: 2, usage: 'Default card elevation' },
  { name: 'Shadow / Medium',   token: '--shadow-md',        value: '0 4px 8px rgba(16,24,40,0.08), 0 2px 4px rgba(16,24,40,0.06)',    level: 3, usage: 'Hover state, elevated panels' },
];

const blurs = [
  { name: 'Background Blur / Button', token: '--blur-button', value: 'blur(24px)', figma: 'Background Blur/Button', usage: 'Glassmorphism navbar and overlays' },
];

const radii = [
  { name: 'Radius / SM',   token: '--radius-sm',   value: '6px',  usage: 'Badges, small chips' },
  { name: 'Radius / MD',   token: '--radius-md',   value: '8px',  usage: 'Buttons, inputs, default cards' },
  { name: 'Radius / LG',   token: '--radius-lg',   value: '12px', usage: 'Component cards, modals' },
  { name: 'Radius / XL',   token: '--radius-xl',   value: '16px', usage: 'Avatar images, testimonial containers' },
  { name: 'Radius / Full', token: '--radius-full', value: '999px', usage: 'Pills, tags, button icon circles' },
];
---
<BaseLayout title="Shadows & Effects" activeNav="shadows">

  <div class="page-hero">
    <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>Foundations</div>
    <h1 class="hero-title">Shadows <em>&amp; Effects</em></h1>
    <p class="hero-desc">Elevation tokens, backdrop blur for glassmorphism, and the five border-radius steps used across all Odama components.</p>
    <div class="hero-meta">
      <div class="hero-meta-item"><span class="hero-meta-label">Shadows</span><span class="hero-meta-value">3 levels</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Blur</span><span class="hero-meta-value">backdrop-filter: blur(24px)</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Border Radius</span><span class="hero-meta-value">5 tokens</span></div>
    </div>
  </div>

  <!-- Shadows -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">01 — Box Shadows</div>
      <div class="section-title">Elevation System</div>
      <div class="section-subtitle">Three shadow levels for surfaces, cards, and hover states</div>
    </div>
    <div class="effect-grid">
      {shadows.map(s => (
        <div class="effect-card">
          <div class="effect-canvas">
            <div class="effect-demo-box" style={`box-shadow:${s.value};`}></div>
          </div>
          <div class="effect-meta">
            <div class="effect-name">{s.name}</div>
            <div class="effect-val">{s.value}</div>
          </div>
        </div>
      ))}
    </div>
    <div style="margin-top:24px;">
      <table class="token-table">
        <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
        <tbody>
          {shadows.map(s => (
            <tr>
              <td><code class="t-name">{s.token}</code></td>
              <td><code class="t-val" style="font-size:10.5px;">{s.value}</code></td>
              <td><span class="t-desc">{s.usage}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Backdrop Blur -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">02 — Backdrop Blur</div>
      <div class="section-title">Glassmorphism</div>
      <div class="section-subtitle">Sourced from Figma's Background Blur/Button effect style</div>
    </div>
    <div class="blur-demo">
      <div class="blur-bg">
        <div class="blur-blob" style="top:20px;left:20px;background:var(--orange);"></div>
        <div class="blur-blob" style="bottom:20px;right:30px;background:#111;width:90px;height:90px;"></div>
        <div class="blur-card">
          <div style="font-size:12px;font-weight:500;color:var(--text-primary);margin-bottom:3px;">Background Blur / Button</div>
          <div style="font-size:11px;color:var(--text-tertiary);">backdrop-filter: blur(24px)</div>
        </div>
      </div>
    </div>
    <div style="margin-top:20px;">
      <table class="token-table">
        <thead><tr><th>Token</th><th>Value</th><th>Figma Style</th><th>Usage</th></tr></thead>
        <tbody>
          {blurs.map(b => (
            <tr>
              <td><code class="t-name">{b.token}</code></td>
              <td><code class="t-val">{b.value}</code></td>
              <td><span class="t-desc">{b.figma}</span></td>
              <td><span class="t-desc">{b.usage}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Border Radius -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">03 — Border Radius</div>
      <div class="section-title">Corner Radius Tokens</div>
      <div class="section-subtitle">Five levels of rounding — from subtle to full pill</div>
    </div>
    <div class="radius-grid">
      {radii.map(r => (
        <div class="radius-card">
          <div class="radius-canvas">
            <div class="radius-box" style={`border-radius:${r.value};`}></div>
          </div>
          <div class="radius-meta">
            <div class="radius-name">{r.name}</div>
            <span class="radius-val">{r.value}</span>
            <div class="radius-usage">{r.usage}</div>
          </div>
        </div>
      ))}
    </div>
    <div style="margin-top:24px;">
      <table class="token-table">
        <thead><tr><th>Token</th><th>Value</th><th>Used on</th></tr></thead>
        <tbody>
          {radii.map(r => (
            <tr>
              <td><code class="t-name">{r.token}</code></td>
              <td><code class="t-val">{r.value}</code></td>
              <td><span class="t-desc">{r.usage}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Live demo -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">04 — In Context</div>
      <div class="section-title">Glassmorphism Nav</div>
      <div class="section-subtitle">backdrop-filter: blur(24px) applied to the Odama navigation</div>
    </div>
    <div style="background:linear-gradient(135deg,var(--orange) 0%,#111 100%);padding:40px 32px;border-radius:var(--radius-lg);position:relative;overflow:hidden;">
      <div style="display:flex;align-items:center;gap:20px;background:rgba(255,255,255,.8);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.3);border-radius:8px;padding:10px 18px;position:relative;z-index:1;box-shadow:var(--shadow-sm);">
        <span style="font-size:14px;font-weight:500;color:#101828;margin-right:auto;">Odama</span>
        <span style="font-size:13px;color:#667085;">About</span>
        <span style="font-size:13px;color:#667085;">Work</span>
        <span style="font-size:13px;color:#667085;">Blog</span>
        <span style="background:#111;color:#fff;font-size:12px;font-weight:500;padding:6px 12px;border-radius:6px;">Let's Talk</span>
      </div>
      <p style="margin-top:10px;font-size:10px;color:rgba(255,255,255,.4);position:relative;z-index:1;font-family:monospace;">backdrop-filter: blur(24px) · bg: rgba(255,255,255,.8) · border-radius: 8px</p>
    </div>
  </div>

</BaseLayout>
<style>
  .blur-demo { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  .blur-bg { position: relative; height: 160px; background: linear-gradient(135deg, var(--bg-subtle), var(--bg-canvas)); overflow: hidden; }
  .blur-blob { position: absolute; width: 100px; height: 100px; border-radius: 50%; opacity: .6; }
  .blur-card { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); background: rgba(255,255,255,.8); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,.5); border-radius: 8px; padding: 14px 20px; white-space: nowrap; box-shadow: var(--shadow-sm); }
</style>
