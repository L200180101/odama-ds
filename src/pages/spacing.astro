---
import BaseLayout from '../layouts/BaseLayout.astro';

const scale = [
  { token: '--space-1',  name: 'space-1',  value: 4,   usage: 'Icon gap, micro-nudges' },
  { token: '--space-2',  name: 'space-2',  value: 8,   usage: 'Button icon padding, tight gaps' },
  { token: '--space-3',  name: 'space-3',  value: 12,  usage: 'Button text padding' },
  { token: '--space-4',  name: 'space-4',  value: 16,  usage: 'Default padding, sidebar gutter' },
  { token: '--space-6',  name: 'space-6',  value: 24,  usage: 'Card gap, section inner padding' },
  { token: '--space-10', name: 'space-10', value: 40,  usage: 'Section horizontal padding' },
  { token: '--space-20', name: 'space-20', value: 80,  usage: 'Testimonial row gap, section top' },
  { token: '--space-24', name: 'space-24', value: 96,  usage: 'Large section spacer' },
  { token: '--space-28', name: 'space-28', value: 110, usage: 'Hero vertical padding' },
  { token: '--space-32', name: 'space-32', value: 128, usage: 'Page-level vertical rhythm' },
  { token: '--space-40', name: 'space-40', value: 160, usage: 'Full-bleed section padding' },
  { token: '--space-50', name: 'space-50', value: 200, usage: 'Maximum layout spacer' },
];
const max = 200;
---
<BaseLayout title="Spacing" activeNav="spacing">

  <div class="page-hero">
    <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>Foundations</div>
    <h1 class="hero-title"><em>Spacing</em></h1>
    <p class="hero-desc">A 12-step spacing scale extracted from the Odama Figma file. From 4px micro-nudges to 200px full-bleed section spacers.</p>
    <div class="hero-meta">
      <div class="hero-meta-item"><span class="hero-meta-label">Steps</span><span class="hero-meta-value">12 tokens</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Range</span><span class="hero-meta-value">4px — 200px</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Base Unit</span><span class="hero-meta-value">4px</span></div>
    </div>
  </div>

  <!-- Visual scale -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">01 — Scale</div>
      <div class="section-title">Spacing Scale</div>
      <div class="section-subtitle">Visual bar chart of all spacing tokens at relative scale</div>
    </div>
    <div class="spacing-rows">
      {scale.map(s => (
        <div class="spacing-row-item">
          <span class="sp-name">{s.name}</span>
          <span class="sp-val">{s.value}px</span>
          <div class="sp-bar-wrap">
            <div class="sp-bar" style={`width:${Math.round((s.value/max)*100)}%;`}></div>
          </div>
          <code class="sp-token">{s.token}</code>
        </div>
      ))}
    </div>
  </div>

  <!-- Token reference -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">02 — Reference</div>
      <div class="section-title">Token Map</div>
    </div>
    <table class="token-table">
      <thead>
        <tr><th>Token</th><th>Value</th><th>Rem</th><th>Usage</th></tr>
      </thead>
      <tbody>
        {scale.map(s => (
          <tr>
            <td><code class="t-name">{s.token}</code></td>
            <td><code class="t-val">{s.value}px</code></td>
            <td><span class="t-desc">{(s.value/16).toFixed(4).replace(/\.?0+$/,'')}rem</span></td>
            <td><span class="t-desc">{s.usage}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Spatial blocks -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">03 — Spatial Reference</div>
      <div class="section-title">Actual Size Blocks</div>
      <div class="section-subtitle">Each block is rendered at its exact pixel value</div>
    </div>
    <div class="spatial-demo">
      {scale.slice(0, 8).map(s => (
        <div class="spatial-item">
          <div class="spatial-block" style={`width:${s.value}px;height:${s.value}px;`}></div>
          <div class="spatial-label">{s.value}px</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Usage patterns -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">04 — In Practice</div>
      <div class="section-title">Component Spacing</div>
      <div class="section-subtitle">How spacing tokens are applied in UI components</div>
    </div>
    <div class="pattern-grid">
      <div class="pattern-card">
        <div class="pattern-label">Button</div>
        <div class="pattern-preview">
          <button class="odama-btn">View More <span class="odama-btn-icon">→</span></button>
        </div>
        <div class="pattern-tokens"><code>gap: 4px</code><code>pad: 10px 14px</code><code>icon-pad: 6px</code></div>
      </div>
      <div class="pattern-card">
        <div class="pattern-label">Card</div>
        <div class="pattern-preview" style="background:var(--bg-canvas);padding:20px;border-radius:8px;border:1px solid var(--border);">
          <div style="font-size:10px;color:var(--text-disabled);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;">Strategy First</div>
          <div style="font-size:15px;font-weight:500;color:var(--text-primary);line-height:1.3;margin-bottom:8px;">We think before we design</div>
          <div style="font-size:12px;color:var(--text-tertiary);">Every brief is interrogated.</div>
        </div>
        <div class="pattern-tokens"><code>pad: 20px</code><code>gap: 12px</code><code>margin-b: 8px</code></div>
      </div>
    </div>
  </div>

</BaseLayout>
<style>
  .spatial-demo { display: flex; flex-wrap: wrap; align-items: flex-end; gap: 20px; padding: 24px; background: var(--bg-canvas); border: 1px solid var(--border); border-radius: var(--radius-lg); }
  .spatial-item { text-align: center; }
  .spatial-block { background: linear-gradient(135deg, var(--orange), rgba(255,91,1,.35)); border-radius: 3px; min-width: 4px; min-height: 4px; margin-bottom: 6px; }
  .spatial-label { font-size: 10px; color: var(--text-tertiary); font-family: monospace; }

  .pattern-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
  .pattern-card { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--bg-surface); }
  .pattern-label { font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: .07em; color: var(--text-disabled); padding: 12px 16px 8px; }
  .pattern-preview { padding: 16px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-canvas); min-height: 80px; display: flex; align-items: center; }
  .pattern-tokens { display: flex; flex-wrap: wrap; gap: 4px; padding: 10px 16px; }
  .pattern-tokens code { font-family: 'SF Mono','Fira Code',monospace; font-size: 10px; background: var(--bg-subtle); color: var(--text-secondary); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }
</style>
