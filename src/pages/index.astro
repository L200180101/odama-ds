---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Overview" activeNav="overview">

  <div class="page-hero">
    <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>Design System</div>
    <h1 class="hero-title">Odama <em>Design System</em></h1>
    <p class="hero-desc">A complete token and component library for Odama Studio — extracted directly from Figma. Colors, typography, spacing, shadows, and live component previews.</p>
    <div class="hero-meta">
      <div class="hero-meta-item"><span class="hero-meta-label">Font</span><span class="hero-meta-value">Switzer</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Colors</span><span class="hero-meta-value">10 tokens</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Type Styles</span><span class="hero-meta-value">8 styles</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Components</span><span class="hero-meta-value">10 components</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Version</span><span class="hero-meta-value">1.0.0</span></div>
    </div>
  </div>

  <!-- About -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">01 — About</div>
      <div class="section-title">What is this?</div>
      <div class="section-subtitle">Design principles and token documentation for Odama Studio's visual language</div>
    </div>
    <p style="font-size:14px;line-height:1.75;color:var(--text-secondary);max-width:620px;margin-bottom:20px;">
      Odama is a digital design studio based in Indonesia, working globally. This design system captures every visual decision — from the brand colors to display typography — so they can be applied consistently across all digital products.
    </p>
    <blockquote style="border-left:3px solid var(--orange);padding:4px 0 4px 20px;font-size:15px;font-weight:500;color:var(--text-primary);line-height:1.5;max-width:520px;">
      "We don't start with visuals. We start with understanding context, constraints, and what matters."
    </blockquote>
  </div>

  <!-- Navigation cards -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">02 — Foundations</div>
      <div class="section-title">Design Tokens</div>
      <div class="section-subtitle">Core decisions encoded as reusable CSS custom properties</div>
    </div>
    <div class="overview-grid">
      <a href="colors" class="overview-card">
        <div class="overview-card-icon">◉</div>
        <div class="overview-card-title">Colors</div>
        <div class="overview-card-desc">10 tokens — brand, neutral, backgrounds, overlay</div>
      </a>
      <a href="typography" class="overview-card">
        <div class="overview-card-icon">T</div>
        <div class="overview-card-title">Typography</div>
        <div class="overview-card-desc">8 styles — 14px body to 128px display</div>
      </a>
      <a href="spacing" class="overview-card">
        <div class="overview-card-icon">↕</div>
        <div class="overview-card-title">Spacing</div>
        <div class="overview-card-desc">12-step scale — 4px to 200px</div>
      </a>
      <a href="shadows" class="overview-card">
        <div class="overview-card-icon">◌</div>
        <div class="overview-card-title">Shadows</div>
        <div class="overview-card-desc">Elevation + blur + border radius</div>
      </a>
      <a href="components" class="overview-card">
        <div class="overview-card-icon">◧</div>
        <div class="overview-card-title">Components</div>
        <div class="overview-card-desc">10 live component previews</div>
      </a>
    </div>
  </div>

  <!-- Brand info -->
  <div class="ds-section">
    <div class="section-header">
      <div class="section-label">03 — Brand</div>
      <div class="section-title">Studio Info</div>
    </div>
    <div class="brand-grid">
      <div class="brand-item"><div class="brand-label">Studio</div><div class="brand-val">Odama Studio</div><div class="brand-sub">Digital Design Agency</div></div>
      <div class="brand-item"><div class="brand-label">Location</div><div class="brand-val">Indonesia</div><div class="brand-sub">Working globally</div></div>
      <div class="brand-item"><div class="brand-label">Contact</div><div class="brand-val">odamastudio@gmail.com</div><div class="brand-sub">+62 822 8898 0909</div></div>
      <div class="brand-item"><div class="brand-label">Stats</div><div class="brand-val">100+ clients</div><div class="brand-sub">5+ years · 22 members</div></div>
    </div>
  </div>

</BaseLayout>
<style>
  .brand-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 24px; }
  .brand-label { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--text-disabled); margin-bottom: 5px; font-weight: 500; }
  .brand-val { font-size: 14px; font-weight: 500; color: var(--text-primary); }
  .brand-sub { font-size: 12px; color: var(--text-tertiary); margin-top: 2px; }
</style>
